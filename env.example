# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/trastalia?retryWrites=true&w=majority&appName=Trastalia

# Google Places API Key (opcional - para autocompletado de ubicaciones)
VITE_GOOGLE_PLACES_API_KEY=development-mode

# Firebase Configuration
VITE_FIREBASE_API_KEY=tu_firebase_api_key_aqui
VITE_FIREBASE_AUTH_DOMAIN=tu_proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu_proyecto_id
VITE_FIREBASE_STORAGE_BUCKET=tu_proyecto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# Vercel URL (para deployment)
VERCEL_URL=tu_dominio_vercel

# Puerto del servidor (opcional)
PORT=3002

# Session Secret (para express-session)
SESSION_SECRET=tu_session_secret_muy_seguro_aqui

# JWT Secret (para autenticación)
JWT_SECRET=tu_jwt_secret_muy_seguro_aqui

# Stripe Configuration
# Obtén tus claves en: https://dashboard.stripe.com/test/apikeys
VITE_STRIPE_PUBLIC_KEY=pk_test_tu_clave_publica_aqui
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_tu_clave_publica_aqui
STRIPE_SECRET_KEY=sk_test_tu_clave_secreta_aqui
STRIPE_WEBHOOK_SECRET=whsec_tu_webhook_secret_aqui

# Frontend URL (para redirecciones de Stripe)
FRONTEND_URL=http://localhost:5173
